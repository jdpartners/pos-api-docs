":{"$ref":"#/components/schemas/RefundRequest"}}},"required":true},"responses":{"201":{"description":"환불 성공","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"400":{"description":"잔액 부족 / 유효성","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"404":{"description":"미등록 전화번호","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/v1/prepayments/deduct":{"post":{"tags":["06. Prepayment"],"summary":"차감 (등록자만)","description":"phone으로 등록된 고객의 잔액에서 차감. 미등록 phone이면 404. 잔액 부족 시 400.","operationId":"deduct","parameters":[{"name":"storeId","in":"query","required":false,"schema":{"type":"integer","format":"int64"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeductRequest"}}},"required":true},"responses":{"201":{"description":"차감 성공","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"400":{"description":"잔액 부족 / 유효성","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"404":{"description":"미등록 전화번호","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/v1/prepayments/charge":{"post":{"tags":["06. Prepayment"],"summary":"충전 (미등록 phone이면 자동 등록)","description":"phone으로 매장 안에서 고객을 찾아 잔액 추가. 미등록자면 name으로 신규 customer 생성 후 충전. 전화번호는 휴대폰/유선/대표번호 모두 허용 — 하이픈·공백은 자동 제거. SA는 storeId 쿼리 파라미터 필요.","operationId":"charge","parameters":[{"name":"storeId","in":"query","required":false,"schema":{"type":"integer","format":"int64"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ChargeRequest"}}},"required":true},"responses":{"201":{"description":"충전 성공 (신규 등록 포함)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"400":{"description":"유효성 / 미등록 phone에 name 미지정 / 전화번호 형식","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"401":{"description":"인증 실패","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}},"403":{"description":"다른 매장 / 권한 없음","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransactionResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/v1/auth/refresh":{"post":{"tags":["01. Auth"],"summary":"토큰 갱신","description":"Refresh Token을 보내면 새로운 Access Token을 발급합니다. lastUsedAt이 업데이트됩니다.","operationId":"refresh","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefreshRequest"}}},"required":true},"responses":{"200":{"description":"갱신 성공, 새 Access Token 발급","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TokenResponse"}}}},"401":{"description":"유효하지 않은 Refresh Token","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TokenResponse"}}}}}}},"/api/v1/auth/logout":{"post":{"tags":["01. Auth"],"summary":"로그아웃","description":"DB에서 해당 Refresh Token을 삭제합니다. Access Token은 필요하지 않습니다 (refreshToken 자체가 자격증명).","operationId":"logout","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefreshRequest"}}},"required":true},"responses":{"200":{"description":"로그아웃 성공 (존재하지 않는 토큰이어도 200)"}}}},"/api/v1/auth/login":{"post":{"tags":["01. Auth"],"summary":"로그인","description":"SUPER_ADMIN은 storeCode 없이 username + password로, 일반 사용자는 storeCode + username + password로 로그인합니다.","operationId":"login","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/LoginRequest"}}},"required":true},"responses":{"200":{"description":"로그인 성공, Access + Refresh Token 발급","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TokenResponse"}}}},"401":{"description":"인증 실패 (잘못된 username 또는 password)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TokenResponse"}}}}}}},"/api/v1/attendances":{"get":{"tags":["04. Attendance"],"summary":"출퇴근 기록 목록 조회","description":"기본 from=to=오늘. SA는 storeId 생략 시 전체 매장 통합. userId 옵션. 일반 사용자는 자기 매장 자동 스코프.","opera